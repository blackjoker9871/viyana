            "index": 0
          }
        ]
      ]
    },
    "check-is-group": {
      "main": [
        [
          {
            "node": "fetch-group-info",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "viyana-ai-request",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch-group-info": {
      "main": [
        [
          {
            "node": "check-group-name",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check-group-name": {
      "main": [
        [
          {
